# Recommended: connect a Neon Postgres integration in Vercel Storage.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Used only to sign the zero-value preview account cookie when no database is set.
DEMO_ACCOUNT_SECRET=replace-with-a-long-random-secret

# Keep preview true and both commerce flags false while the site uses archived
# catalogue prices. All three values are build/deployment settings.
NEXT_PUBLIC_CATALOGUE_PREVIEW_ONLY=true
COMMERCE_LIVE=false
NEXT_PUBLIC_COMMERCE_LIVE=false
# Required before live Stripe checkout. Use the canonical HTTPS website origin.
APP_BASE_URL=https://example.com
STORE_TIMEZONE=Australia/Melbourne
DELIVERY_CAPACITY_PER_WINDOW=8

# Express delivery: flat $10 fee with server-side Google Places + Routes used
# only to validate the delivery zone. Resolve and save the Place ID for 119
# Highlander Dr, Craigieburn VIC 3064.
GOOGLE_MAPS_API_KEY=replace_with_restricted_server_key
GOOGLE_SHOP_PLACE_ID=replace_with_shop_place_id
DELIVERY_QUOTE_SECRET=replace-with-at-least-32-random-characters
DELIVERY_QUOTE_TTL_SECONDS=600
EXPRESS_MAX_DISTANCE_KM=40

# Normal delivery is a next-business-day Australia Post dispatch. Keep the
# public and server values identical so the displayed and charged fees match.
AUSPOST_NEXT_DAY_FEE_CENTS=1200
NEXT_PUBLIC_AUSPOST_NEXT_DAY_FEE_CENTS=1200
AUSPOST_ORDER_CUTOFF_HOUR=15
NEXT_PUBLIC_AUSPOST_ORDER_CUTOFF_HOUR=15
# Comma-separated Melbourne dates when normal dispatch is closed, YYYY-MM-DD.
AUSPOST_CLOSED_DATES=
NEXT_PUBLIC_AUSPOST_CLOSED_DATES=

# Platform Stripe key + Liquor Stax connected account. Checkout creates a
# direct charge on the shop account and settles the disclosed 99c application
# fee to Techbykennedy. Use a Connect webhook secret.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CONNECTED_ACCOUNT_ID=acct_replace_me
STORE_ABN=

# Owner portal. Generate ADMIN_PASSWORD_HASH with the documented scrypt helper
# format; never place a plaintext password in deployment settings.
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD_HASH=scrypt$16384$8$1$replace_salt$replace_digest
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Vercel sends this bearer token to the weekday Australia Post report job.
CRON_SECRET=replace-with-at-least-32-random-characters

# Email confirmations and owner dispatch alerts.
RESEND_API_KEY=re_replace_me
EMAIL_FROM=Liquor Stax <orders@example.com>
OWNER_DISPATCH_EMAIL=liquorstaxconline@gmail.com

# Optional transactional SMS receipts and owner alerts. WhatsApp is not used for alcohol orders.
TWILIO_ACCOUNT_SID=AC_replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_MESSAGING_SERVICE_SID=MG_replace_me
TWILIO_FROM_E164=
OWNER_DISPATCH_SMS_E164=

# Shopfront OAuth/sync readiness. Product sync remains disabled until the
# owner confirms plan, subdomain, outlet/register, price set and payment IDs.
SHOPFRONT_VENDOR_SUBDOMAIN=
SHOPFRONT_CLIENT_ID=
SHOPFRONT_CLIENT_SECRET=
SHOPFRONT_OUTLET_ID=
SHOPFRONT_REGISTER_ID=
SHOPFRONT_PRICE_SET_ID=
SHOPFRONT_PAYMENT_METHOD_ID=
# Keep false until signed Shopfront product/inventory sync is operating and
# its stock snapshots are verified in store_products.
SHOPFRONT_INVENTORY_SYNC_LIVE=false

# Required legal activation controls for Victorian off-premises ordering.
# Display the same confirmed licence number publicly and server-side. Set the
# notification flag only after Liquor Control Victoria has acknowledged it.
LIQUOR_LICENCE_NUMBER=
NEXT_PUBLIC_LIQUOR_LICENCE_NUMBER=
LCV_OFF_PREMISES_NOTIFIED=false
